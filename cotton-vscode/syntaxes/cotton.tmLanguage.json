{
  "name": "Cotton",
  "scopeName": "source.cotton",
  "fileTypes": ["cot", "cotton"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#declarations" },
    { "include": "#types" },
    { "include": "#literals" },
    { "include": "#operators" },
    { "include": "#support" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.cotton",
          "begin": "//",
          "end": "$",
          "patterns": [
            {
              "name": "comment.line.todo.cotton",
              "match": "\\b(TODO|FIXME|NOTE|XXX|HACK)\\b"
            }
          ]
        },
        {
          "name": "comment.block.cotton",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            {
              "name": "comment.block.todo.cotton",
              "match": "\\b(TODO|FIXME|NOTE)\\b"
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.cotton",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "name": "string.quoted.triple.cotton",
          "patterns": [
            {
              "name": "constant.character.escape.cotton",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.interpolated.cotton",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "constant.character.escape.cotton",
              "match": "\\\\`"
            },
            {
              "name": "meta.template.expression.cotton",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.definition.template-expression.begin.cotton" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.definition.template-expression.end.cotton" }
              },
              "patterns": [
                { "include": "$self" }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.double.cotton",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.cotton", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.single.cotton",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.cotton", "match": "\\\\." }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.cotton",
          "match": "\\b(if|else|for|in|while|loop|match|break|continue|return|where)\\b"
        },
        {
          "name": "keyword.other.cotton",
          "match": "\\b(let|mut|const|fn|struct|enum|impl|trait|module|import|from|pub|as|self|Self|async|await|spawn|channel|unsafe|Box|not|and|or|outer)\\b"
        },
        {
          "name": "keyword.operator.cotton",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.function.definition.cotton",
          "begin": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "beginCaptures": {
            "1": { "name": "keyword.other.fn.cotton" },
            "2": { "name": "entity.name.function.cotton" }
          },
          "end": "(?=\\{|;)",
          "patterns": [
            { "include": "#types" },
            { "include": "#comments" }
          ]
        },
        {
          "name": "meta.struct.definition.cotton",
          "match": "\\b(struct|enum|trait|module|impl)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.type-def.cotton" },
            "2": { "name": "entity.name.type.cotton" }
          }
        },
        {
          "name": "meta.let.definition.cotton",
          "match": "\\b(let)\\s+(mut\\s+)?([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.let.cotton" },
            "2": { "name": "keyword.other.mut.cotton" },
            "3": { "name": "variable.other.cotton" }
          }
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.cotton",
          "match": "\\b(i32|i64|u8|u32|u64|f32|f64|str|bool|char|Option|Result|Box|Vec|Stack|Queue|Point|Shape|Error)\\b"
        },
        {
          "name": "storage.type.generic.cotton",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b"
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "constant.language.boolean.cotton",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.option.cotton",
          "match": "\\b(None|Some|Ok|Err|nil)\\b"
        },
        {
          "name": "constant.numeric.float.cotton",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.cotton",
          "match": "\\b[0-9][0-9_]*\\b"
        },
        {
          "name": "variable.language.cotton",
          "match": "\\bself\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.cotton",
          "match": "->|=>|\\?\\?|\\?\\.|\\?"
        },
        {
          "name": "keyword.operator.range.cotton",
          "match": "\\.\\.=?|\\|"
        },
        {
          "name": "keyword.operator.comparison.cotton",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.cotton",
          "match": "=(?!=)|\\+=|-=|\\*=|/=|%="
        },
        {
          "name": "keyword.operator.arithmetic.cotton",
          "match": "\\+|-|\\*\\*|\\*|/|%|&mut|&"
        },
        {
          "name": "punctuation.separator.cotton",
          "match": ",|:|;"
        },
        {
          "name": "punctuation.bracket.cotton",
          "match": "[\\{\\}\\[\\]\\(\\)]"
        }
      ]
    },
    "support": {
      "patterns": [
        {
          "name": "support.function.builtin.cotton",
          "match": "\\b(print|println|len|sqrt|Box|channel|spawn|Ok|Err|Some)\\b(?=\\s*[\\(\\{`])"
        },
        {
          "name": "entity.name.function.method.cotton",
          "match": "(?<=\\.)\\s*([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()"
        },
        {
          "name": "variable.other.property.cotton",
          "match": "(?<=\\.)\\s*([a-zA-Z_][a-zA-Z0-9_]*)"
        }
      ]
    }
  }
}
