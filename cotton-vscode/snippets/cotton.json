{
  "Function": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:ReturnType} {",
      "    ${0}",
      "}"
    ],
    "description": "Define a function"
  },
  "Struct": {
    "prefix": "struct",
    "body": [
      "struct ${1:Name} {",
      "    ${2:field}: ${3:Type}",
      "}"
    ],
    "description": "Define a struct"
  },
  "Impl": {
    "prefix": "impl",
    "body": [
      "impl ${1:Type} {",
      "    fn ${2:method}(self, ${3:other}: ${4:Type}) -> ${5:ReturnType} {",
      "        ${0}",
      "    }",
      "}"
    ],
    "description": "Impl block"
  },
  "Let immutable": {
    "prefix": "let",
    "body": ["let ${1:name} = ${0}"],
    "description": "Immutable variable"
  },
  "Let mutable": {
    "prefix": "letmut",
    "body": ["let mut ${1:name} = ${0}"],
    "description": "Mutable variable"
  },
  "For loop": {
    "prefix": "for",
    "body": [
      "for ${1:item} in ${2:iter} {",
      "    ${0}",
      "}"
    ],
    "description": "For in loop"
  },
  "If else": {
    "prefix": "if",
    "body": [
      "if ${1:condition} {",
      "    ${2}",
      "} else {",
      "    ${0}",
      "}"
    ],
    "description": "If else"
  },
  "Match": {
    "prefix": "match",
    "body": [
      "match ${1:value} {",
      "    ${2:pattern} => ${3:body},",
      "    _ => ${0}",
      "}"
    ],
    "description": "Match expression"
  },
  "Result handling ?": {
    "prefix": "?",
    "body": ["${1:expr}?"],
    "description": "Propagate Result"
  },
  "Closure": {
    "prefix": "closure",
    "body": ["|${1:x}| ${0}"],
    "description": "Closure |x| ..."
  },
  "Template string": {
    "prefix": "tstr",
    "body": ["`${1:text} \\${${2:var}} ${0}`"],
    "description": "Interpolated string"
  },
  "Closest pair example": {
    "prefix": "closestpair",
    "body": [
      "struct Point { x: f64 y: f64 }",
      "impl Point {",
      "    fn distance(self, other: Point) -> f64 {",
      "        ((self.x - other.x) ** 2 + (self.y - other.y) ** 2).sqrt()",
      "    }",
      "}",
      "",
      "fn closest_pair(points: [Point]) -> (Point, Point) {",
      "    let mut best = (points[0], points[1])",
      "    let mut best_dist = points[0].distance(points[1])",
      "    for i in 0..points.len() {",
      "        for j in (i + 1)..points.len() {",
      "            let d = points[i].distance(points[j])",
      "            if d < best_dist {",
      "                best_dist = d",
      "                best = (points[i], points[j])",
      "            }",
      "        }",
      "    }",
      "    best",
      "}"
    ],
    "description": "Full closest pair example from spec"
  }
}
